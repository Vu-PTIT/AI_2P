# Use 127.0.0.1 when AI and realtime-service run on the same VPS.
# Use 0.0.0.0 when realtime-service connects from another container/host.
AI_WS_HOST=127.0.0.1
AI_WS_PORT=8765

WHISPER_MODEL=large-v3
WHISPER_MODEL_DIR=./models/whisper
WHISPER_DEVICE=cpu
# Optional fallback for direct ASREngine callers. Live sessions override this
# per client with localLanguage/speaker, so do not force vi for every meeting.
# WHISPER_LANGUAGE=vi

AUDIO_DENOISE=gate
AUDIO_VAD=silero
AUDIO_DIARIZATION=off
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
# PYANNOTE_AUTH_TOKEN=replace-with-your-huggingface-token

FPT_FAST_MT_MODEL=DeepSeek-V4-Flash
FAST_MT_TIMEOUT=3.0

# --- FPT AI Marketplace ---
# Get your API key from https://marketplace.fptcloud.com/en/my-account#my-api-key
# One key is enough for ASR, translation, embedding, and reranking.
FPT_API_KEY=replace-with-your-fpt-api-key
FPT_BASE_URL=https://mkp-api.fptcloud.com

# Quality Path LLM (chat/completions)
FPT_AI_FACTORY_BASE_URL=https://mkp-api.fptcloud.com
FPT_AI_FACTORY_MODEL=SaoLa3.1-medium
FPT_AI_FACTORY_TIMEOUT=3.0

# ASR via FPT API (set true to use API, false to use local whisper)
FPT_ASR=false
FPT_ASR_MODEL=FPT.AI-whisper-large-v3-turbo
FPT_ASR_PREFLIGHT_TIMEOUT=10

# Embedding & Reranker via FPT API
FPT_EMBEDDING=true
FPT_EMBEDDING_MODEL=Vietnamese_Embedding
FPT_RERANKER=true
FPT_RERANKER_MODEL=bge-reranker-v2-m3

# Backward-compatible aliases if you are not using FPT AI Marketplace:
# QUALITY_LLM_BASE_URL=http://localhost:8000/v1
# QUALITY_LLM_API_KEY=local
# QUALITY_LLM_MODEL=your-llm-model
# QUALITY_LLM_TIMEOUT=1.0

RAG_EMBEDDING_MODEL=Vietnamese_Embedding
RAG_QDRANT_PATH=./data/qdrant_local
RAG_COLLECTION=meeting_docs
RAG_ALLOWED_ROOT=./data

# Enable only when session IDs are trusted/sanitized by the deployment.
# SESSION_EXPORT_DIR=./data/session_exports
OVERLAP_BUFFER_LIMIT=20
